---
Language: Cpp
# This sets the base to a style that prefers broken braces
BreakBeforeBraces: Allman

# This forces the return type to be on its own line for all functions
AlwaysBreakAfterReturnType: AllDefinitions

# Tab and Indentation settings
UseTab: Never              # Use spaces to represent tabs
IndentWidth: 8             # "2 tabs" where each is 4 spaces = 8 spaces total
TabWidth: 4                # Define the logical width of a single tab

# General cleanup
ColumnLimit: 80
AllowShortFunctionsOnASingleLine: false
IndentCaseLabels: true
AlignConsecutiveAssignments: true
AlignConsecutiveDeclarations: true
---
